# Copie este arquivo para .env e preencha com sua chave real da Perplexity.
# Obtenha em: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Modelo padrão (sonar = rápido/barato; sonar-pro = mais profundo)
PERPLEXITY_MODEL=sonar

# Origens permitidas para CORS (frontend Vite)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
